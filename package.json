{
  "name": "cplusplusplus-vscode",
  "displayName": "C+++ VSCode",
  "description": "C+++ (C++ Plus Plus Plus) language support for VSCode",
  "version": "0.1.0",
  "publisher": "cplusplusplus",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:cpp",
    "onCommand:cplusplusplus.compile"
  ],
  "main": "out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cpp",
        "extensions": [".cpp", ".cc", ".cxx", ".c++", ".c+++"],
        "aliases": ["C++", "cpp"]
      }
    ],
    "grammars": [
      {
        "language": "cpp",
        "scopeName": "source.cpp",
        "path": "./src/language/grammar.json"
      }
    ],
    "snippets": [
      {
        "language": "cpp",
        "path": "./src/language/snippets.json"
      }
    ],
    "commands": [
      {
        "command": "cplusplusplus.compile",
        "title": "C+++: Compile"
      }
    ],
    "configuration": {
      "title": "C+++",
      "properties": {
        "cplusplusplus.pluginPath": {
          "type": "string",
          "default": "",
          "description": "Path to C+++ plugin library"
        },
        "cplusplusplus.clangPath": {
          "type": "string",
          "default": "clang++",
          "description": "Path to clang++ executable"
        },
        "cplusplusplus.enableSyntaxHighlighting": {
          "type": "boolean",
          "default": true,
          "description": "Enable C+++ syntax highlighting"
        },
        "cplusplusplus.enableCodeSnippets": {
          "type": "boolean",
          "default": true,
          "description": "Enable C+++ code snippets"
        },
        "cplusplusplus.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable C+++ hover information"
        },
        "cplusplusplus.enableQuickFix": {
          "type": "boolean",
          "default": true,
          "description": "Enable C+++ quick fix suggestions"
        },
        "cplusplusplus.cmakePath": {
          "type": "string",
          "default": "cmake",
          "description": "Path to CMake executable"
        },
        "cplusplusplus.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional include paths"
        },
        "cplusplusplus.compilerFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional compiler flags"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.2",
    "@types/node": "14.x",
    "glob": "^7.1.7",
    "mocha": "^8.3.2",
    "typescript": "^4.4.3",
    "vscode-test": "^1.5.2"
  }
}